{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-sveltekit/main/.vscode/schema/tauri.conf.json",
  "productName": "Secret Letter",
  "version": "1.8.0",
  "identifier": "com.textfyre.secretletter",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Jack Toresal and The Secret Letter",
        "width": 900,
        "height": 650,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
